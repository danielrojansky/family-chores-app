# ─── Required ────────────────────────────────────────────────────────────────
# Upstash Redis (from Upstash Console → Database → REST API)
KV_REST_API_URL=https://your-redis-id.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# Google OAuth 2.0 (from Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Production only (set in Vercel Dashboard) ──────────────────────────────
# Full origin URL for CORS restriction (e.g. https://your-app.vercel.app)
# APP_ORIGIN=https://your-app.vercel.app

# Admin Google account email — locks admin panel to Google-only login
# ADMIN_EMAIL=you@gmail.com

# WebAuthn relying party ID — hostname only, no https:// (e.g. your-app.vercel.app)
# RP_ID=your-app.vercel.app

# ─── Optional ────────────────────────────────────────────────────────────────
# One-time setup key for first admin login (not needed when ADMIN_EMAIL is set)
# ADMIN_SETUP_KEY=any-long-random-secret
